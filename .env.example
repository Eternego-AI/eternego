# Eternego configuration
# Copy this file to .env and edit as needed

# Web server
WEB_HOST=127.0.0.1
WEB_PORT=5000

# OpenAI API timeout in seconds
OPENAI_TIMEOUT=30

# ── Fine-tuning (LoRA) ────────────────────────────────────────────────────────
# Defaults below are tuned for a Mac Mini M4 with 24 GB unified memory.
# Adjust to match your machine's memory and compute capabilities.

# LoRA rank — higher = more expressive, more memory (4, 8, 16)
LORA_R=8

# LoRA alpha — scaling factor, typically 2× rank
LORA_ALPHA=16

# LoRA dropout
LORA_DROPOUT=0.05

# Modules to apply LoRA to.
# "q_proj,k_proj,v_proj,o_proj" — attention only (faster, less memory)
# "all-linear" — all linear layers (slower, more expressive)
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj

# Max token length per training example (256, 512, 1024)
# Shorter = faster and less memory
FINETUNE_MAX_LENGTH=512

# Samples per gradient step
FINETUNE_BATCH_SIZE=2

# Gradient accumulation steps — effective batch = BATCH_SIZE × GRAD_ACCUM
FINETUNE_GRAD_ACCUM=4

# Training epochs over the nightly training set
FINETUNE_EPOCHS=1

# Learning rate
FINETUNE_LEARNING_RATE=2e-4

# Recompute activations to save ~4 GB memory at ~30% speed cost.
# Enable on CUDA with limited VRAM. Disable when memory is ample.
FINETUNE_GRADIENT_CHECKPOINTING=false
